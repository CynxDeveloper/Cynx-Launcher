<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <AssemblyName>SusanooLauncher</AssemblyName>
    <RootNamespace>SusanooLauncher</RootNamespace>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <Version>1.0.0</Version>
    <AssemblyVersion>1.0.0.0</AssemblyVersion>
    <FileVersion>1.0.0.0</FileVersion>
    <Product>Susanoo Launcher</Product>
    <AssemblyTitle>Susanoo Launcher</AssemblyTitle>
    <Company>Susanoo</Company>
	<AllowUnsafeBlocks>true</AllowUnsafeBlocks>
  </PropertyGroup>

  <ItemGroup>
    <None Remove="Starfall.dll" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="DiscordRichPresence" Version="1.6.1.70" />
    <PackageReference Include="MongoDB.Driver" Version="2.28.0" />
    <PackageReference Include="NAudio" Version="2.3.0" />
    <PackageReference Include="WPF-UI" Version="3.0.4" />
  </ItemGroup>

  <ItemGroup>
    <Resource Include="Starfall.dll" />
  </ItemGroup>

  <ItemGroup>
    <Compile Update="Settings.Designer.cs">
      <DesignTimeSharedInput>True</DesignTimeSharedInput>
      <AutoGen>True</AutoGen>
      <DependentUpon>Settings.settings</DependentUpon>
    </Compile>
  </ItemGroup>

  <ItemGroup>
    <None Update="Settings.settings">
      <Generator>SettingsSingleFileGenerator</Generator>
      <LastGenOutput>Settings.Designer.cs</LastGenOutput>
    </None>
  </ItemGroup>

  <ItemGroup>
    <None Update="launcher.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Update="Assets\Sounds\navigation.mp4">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

  <ItemGroup>
    <Resource Include="Assets\susanoo.png" />
  </ItemGroup>

  <ItemGroup>
    <Resource Include="Assets\Home\*.png" />
  </ItemGroup>

  <Target Name="CopyArcClient" AfterTargets="Build">
    <PropertyGroup>
      <ArcBuiltPath>$(MSBuildProjectDirectory)\..\Arc\x64\Release\Arc.exe</ArcBuiltPath>
      <ArcBuiltPath Condition="!Exists('$(ArcBuiltPath)')">$(MSBuildProjectDirectory)\..\Arc\Arc\x64\Release\Arc.exe</ArcBuiltPath>
      <ArcBuiltPath Condition="!Exists('$(ArcBuiltPath)')">$(MSBuildProjectDirectory)\..\Arc\build\Arc.exe</ArcBuiltPath>
    </PropertyGroup>
    <Copy Condition="Exists('$(ArcBuiltPath)')"
          SourceFiles="$(ArcBuiltPath)"
          DestinationFiles="$(OutputPath)Arc.exe"
          SkipUnchangedFiles="false" />
  </Target>

