<Page x:Class="SusanooLauncher.Pages.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      mc:Ignorable="d"
      Background="Transparent">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="1" CornerRadius="16" Background="#E61A1F2E" Padding="28" HorizontalAlignment="Center" Width="480"
                BorderBrush="#FF252B3D" BorderThickness="1">
            <StackPanel>
                <Grid Margin="0,0,0,22" HorizontalAlignment="Center">
                    <Border CornerRadius="16" Width="72" Height="72" Background="Transparent" ClipToBounds="True">
                        <Image Source="pack://application:,,,/Assets/susanoo.png" Stretch="Uniform" />
                    </Border>
                </Grid>
                <TextBlock x:Name="TitleText" Text="Susanoo Launcher" FontSize="22" FontWeight="SemiBold" Foreground="#FFFFFFFF" HorizontalAlignment="Center" />
                <TextBlock x:Name="SubtitleText" Margin="0,6,0,22" Text="Sign in to continue" Foreground="#99FFFFFF" HorizontalAlignment="Center" />

                <TextBlock x:Name="RegisterUsernameLabel" Text="Username" Foreground="#CCFFFFFF" FontSize="13" Visibility="Collapsed" />
                <ui:TextBox x:Name="RegisterUsername" Margin="0,6,0,0" PlaceholderText="Username..." Visibility="Collapsed" />

                <TextBlock x:Name="DiscordIdLabel" Text="Discord User ID" Foreground="#CCFFFFFF" FontSize="13" Margin="0,14,0,0" Visibility="Collapsed" />
                <ui:TextBox x:Name="DiscordIdBox" Margin="0,6,0,0" PlaceholderText="Right-click your profile → Copy User ID" Visibility="Collapsed" />
                <TextBlock x:Name="DiscordIdHint" Margin="0,4,0,0" Text="Your account details will be sent to your Discord DMs." Foreground="#66FFFFFF" FontSize="11" TextWrapping="Wrap" Visibility="Collapsed" />

                <TextBlock Text="Email" Foreground="#CCFFFFFF" FontSize="13" Margin="0,0,0,0" />
                <ui:TextBox x:Name="Username" Margin="0,6,0,0" PlaceholderText="Email..." />

                <TextBlock Margin="0,14,0,0" Text="Password" Foreground="#CCFFFFFF" FontSize="13" />
                <ui:PasswordBox x:Name="Password" Margin="0,6,0,0" PlaceholderText="Password..." />

                <TextBlock x:Name="ErrorText" Margin="0,14,0,0" TextWrapping="Wrap" Foreground="#FFFF6B6B" FontSize="12" Visibility="Collapsed" />

                <ui:Button x:Name="ContinueBtn" Margin="0,22,0,0" Height="42" Click="ContinueClicked" Content="Continue" />
                <ui:Button x:Name="ToggleModeBtn" Margin="0,10,0,0" Height="36" Appearance="Secondary" Click="ToggleModeClicked" Content="Create an account" />
            </StackPanel>
        </Border>
    </Grid>
</Page>
