<Page x:Class="SusanooLauncher.Pages.SupportPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      mc:Ignorable="d"
      Background="Transparent">

    <Grid>
        <Border CornerRadius="18" Background="#22000000" Padding="24" HorizontalAlignment="Center" VerticalAlignment="Center" Width="620">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="Support" FontSize="30" FontWeight="SemiBold" Foreground="#F2FFFFFF" />
                <TextBlock Margin="0,8,0,16" Foreground="#CCFFFFFF" Text="Need help? Join the Susanoo Support Discord Server." />
                <ui:Button Width="280" Height="42" Content="Open Discord Support" Click="OpenDiscordClicked" />
            </StackPanel>
        </Border>
    </Grid>
</Page>

