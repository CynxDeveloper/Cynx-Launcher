<Page x:Class="SusanooLauncher.Pages.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Background="Transparent">

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="28,20,28,24">
            <StackPanel MaxWidth="720">
                <TextBlock Text="Appearance and Behavior" Foreground="#66FFFFFF" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,10" />

                <Border Background="#D91A1F2E" CornerRadius="14" Padding="4" Margin="0,0,0,24">
                    <StackPanel>
                        <Grid Margin="16,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Sound Effects" Foreground="#FFFFFFFF" FontWeight="SemiBold" />
                                <TextBlock Text="Hear sound effects while navigating the launcher menus." Foreground="#88FFFFFF" FontSize="12" Margin="0,4,0,0" TextWrapping="Wrap" />
                            </StackPanel>
                            <CheckBox x:Name="SoundEffectsToggle" Grid.Column="1" VerticalAlignment="Center" Checked="SettingChanged" Unchecked="SettingChanged" />
                        </Grid>
                        <Border Height="1" Background="#FF252B3D" Margin="16,0" />
                        <Grid Margin="16,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Bubble Builds" Foreground="#FFFFFFFF" FontWeight="SemiBold" />
                                <TextBlock Text="Enable Bubble Wrap Builds as your building style in-game." Foreground="#88FFFFFF" FontSize="12" Margin="0,4,0,0" TextWrapping="Wrap" />
                            </StackPanel>
                            <CheckBox x:Name="BubbleBuildsToggle" Grid.Column="1" VerticalAlignment="Center" Checked="SettingChanged" Unchecked="SettingChanged" />
                        </Grid>
                        <Border Height="1" Background="#FF252B3D" Margin="16,0" />
                        <Grid Margin="16,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Live Moving Background" Foreground="#FFFFFFFF" FontWeight="SemiBold" />
                                <TextBlock Text="Animated circles or squares behind the launcher." Foreground="#88FFFFFF" FontSize="12" Margin="0,4,0,0" TextWrapping="Wrap" />
                            </StackPanel>
                            <CheckBox x:Name="LiveBackgroundToggle" Grid.Column="1" VerticalAlignment="Center" Checked="SettingChanged" Unchecked="SettingChanged" />
                        </Grid>
                        <Border Height="1" Background="#FF252B3D" Margin="16,0" />
                        <Grid Margin="16,14">
                            <StackPanel>
                                <TextBlock Text="Background Shape" Foreground="#FFFFFFFF" FontWeight="SemiBold" />
                                <TextBlock Text="Choose circles or squares for the live background." Foreground="#88FFFFFF" FontSize="12" Margin="0,4,0,8" />
                                <ComboBox x:Name="BackgroundShapeCombo" Height="36" SelectionChanged="BackgroundShapeChanged">
                                    <ComboBoxItem Content="Circles" />
                                    <ComboBoxItem Content="Squares" />
                                </ComboBox>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <TextBlock Text="Account &amp; Game" Foreground="#66FFFFFF" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,10" />
                <Border Background="#D91A1F2E" CornerRadius="14" Padding="16" Margin="0,0,0,24">
                    <StackPanel>
                        <TextBlock Text="Support-A-Creator Code" Foreground="#FFFFFFFF" FontWeight="SemiBold" />
                        <TextBox x:Name="SacCodeBox" Margin="0,8,0,12" Height="36" TextChanged="SacChanged" />
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Streamer mode (hide email)" Foreground="#FFFFFFFF" VerticalAlignment="Center" />
                            <CheckBox x:Name="StreamerModeToggle" Grid.Column="1" Checked="FeaturePrefChanged" Unchecked="FeaturePrefChanged" />
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="High contrast UI" Foreground="#FFFFFFFF" VerticalAlignment="Center" />
                            <CheckBox x:Name="HighContrastToggle" Grid.Column="1" Checked="FeaturePrefChanged" Unchecked="FeaturePrefChanged" />
                        </Grid>
                    </StackPanel>
                </Border>

                <TextBlock Text="About" Foreground="#66FFFFFF" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,10" />
                <Border Background="#D91A1F2E" CornerRadius="14" Padding="16" Margin="0,0,0,24">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Width="48" Height="48" CornerRadius="12" ClipToBounds="True" VerticalAlignment="Center">
                            <Image Source="pack://application:,,,/Assets/susanoo.png" Stretch="Uniform" />
                        </Border>
                        <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="About Susanoo Launcher" Foreground="#FFFFFFFF" FontWeight="SemiBold" />
                            <TextBlock Text="1.0.0" Foreground="#88FFFFFF" Margin="0,4,0,0" />
                        </StackPanel>
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <ui:Button Content="Log Out" Click="LogOutClicked" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                   Margin="0,0,28,24" Height="40" MinWidth="100" Background="#FFE53935" Foreground="#FFFFFFFF" />
    </Grid>
</Page>
