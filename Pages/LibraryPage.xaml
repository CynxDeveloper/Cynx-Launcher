<Page x:Class="SusanooLauncher.Pages.LibraryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      mc:Ignorable="d"
      Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="Transparent">
        <StackPanel Margin="28,22,28,22" MaxWidth="980">
            <TextBlock Text="Library" FontSize="26" FontWeight="SemiBold" Foreground="#F2FFFFFF" />
            <TextBlock Margin="0,6,0,18" Opacity="0.95" Foreground="#CCFFFFFF"
                       Text="Select your Fortnite build folder, then press Launch.." />

            <Border CornerRadius="16" Background="#22000000" Padding="18" Margin="0,0,0,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border Width="180" Height="100" CornerRadius="12" Background="#331A1F2E" ClipToBounds="True">
                        <Grid>
                            <Image x:Name="BuildSplashImage" Stretch="UniformToFill" />
                            <TextBlock x:Name="SplashPlaceholderText" Text="No splash"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="#66FFFFFF" FontSize="12" />
                        </Grid>
                    </Border>

                    <StackPanel Grid.Column="1" Margin="18,0,16,0" VerticalAlignment="Center">
                        <TextBlock Text="Build name" Opacity="1" Foreground="#99FFFFFF" FontSize="12" />
                        <TextBlock x:Name="BuildNameText" Margin="0,4,0,10" FontSize="20" FontWeight="SemiBold"
                                   Foreground="#F2FFFFFF" TextWrapping="Wrap" Text="No build selected" />

                        <TextBlock Text="Build path" Opacity="1" Foreground="#99FFFFFF" FontSize="12" />
                        <TextBlock x:Name="PathText" Margin="0,4,0,0" FontSize="13" TextWrapping="Wrap"
                                   Foreground="#CCFFFFFF" Text="(not set)" />
                    </StackPanel>

                    <ui:Button Grid.Column="2" Width="140" VerticalAlignment="Center" Click="SelectFolder"
                               Content="Select folder" />
                </Grid>
            </Border>

            <Border CornerRadius="16" Background="#22000000" Padding="18">
                <StackPanel>
                    <TextBlock Text="Status" Opacity="1" Foreground="#E6FFFFFF" />
                    <TextBlock x:Name="StatusText" Margin="0,6,0,12" Text="Ready" TextWrapping="Wrap" Foreground="#F2FFFFFF" />
                    <ui:Button x:Name="LaunchButton" Height="38" Width="160" Click="Launch" Content="Launch" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
