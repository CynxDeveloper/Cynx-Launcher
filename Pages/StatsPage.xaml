<Page x:Class="SusanooLauncher.Pages.StatsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Background="Transparent">

    <Grid Margin="28,22,28,22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal">
            <TextBlock Text="My Stats" FontSize="26" FontWeight="SemiBold" Foreground="#F2FFFFFF" />
            <ui:Button Content="Refresh" Margin="16,0,0,0" Height="32" Click="RefreshClicked" Appearance="Secondary" />
        </StackPanel>

        <UniformGrid Grid.Row="1" Margin="0,20,0,0" Columns="2" Rows="3">
            <Border Margin="0,0,8,8" CornerRadius="14" Background="#D91A1F2E" Padding="18">
                <StackPanel>
                    <TextBlock Text="Arena Points" Foreground="#88FFFFFF" FontSize="12" />
                    <TextBlock x:Name="PointsText" Text="—" FontSize="28" FontWeight="Bold" Foreground="#FFFFFFFF" Margin="0,6,0,0" />
                </StackPanel>
            </Border>
            <Border Margin="8,0,0,8" CornerRadius="14" Background="#D91A1F2E" Padding="18">
                <StackPanel>
                    <TextBlock Text="Kills" Foreground="#88FFFFFF" FontSize="12" />
                    <TextBlock x:Name="KillsText" Text="—" FontSize="28" FontWeight="Bold" Foreground="#FFFFFFFF" Margin="0,6,0,0" />
                </StackPanel>
            </Border>
            <Border Margin="0,0,8,8" CornerRadius="14" Background="#D91A1F2E" Padding="18">
                <StackPanel>
                    <TextBlock Text="Wins" Foreground="#88FFFFFF" FontSize="12" />
                    <TextBlock x:Name="WinsText" Text="—" FontSize="28" FontWeight="Bold" Foreground="#FFFFFFFF" Margin="0,6,0,0" />
                </StackPanel>
            </Border>
            <Border Margin="8,0,0,8" CornerRadius="14" Background="#D91A1F2E" Padding="18">
                <StackPanel>
                    <TextBlock Text="Play Time" Foreground="#88FFFFFF" FontSize="12" />
                    <TextBlock x:Name="PlayTimeText" Text="—" FontSize="28" FontWeight="Bold" Foreground="#FFFFFFFF" Margin="0,6,0,0" />
                </StackPanel>
            </Border>
            <Border Margin="0,0,8,0" Grid.ColumnSpan="2" CornerRadius="14" Background="#D91A1F2E" Padding="18">
                <StackPanel>
                    <TextBlock Text="Achievements" Foreground="#88FFFFFF" FontSize="12" />
                    <TextBlock x:Name="AchievementsText" Text="—" FontSize="14" Foreground="#CCFFFFFF" Margin="0,6,0,0" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </UniformGrid>
    </Grid>
</Page>
