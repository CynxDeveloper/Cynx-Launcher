<Page x:Class="SusanooLauncher.Pages.NewsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Background="Transparent">

    <Grid Margin="28,22,28,22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal">
            <TextBlock Text="News" FontSize="26" FontWeight="SemiBold" Foreground="#F2FFFFFF" />
            <ui:Button Content="Refresh" Margin="16,0,0,0" Height="32" Click="RefreshClicked" Appearance="Secondary" />
        </StackPanel>

        <ScrollViewer Grid.Row="1" Margin="0,16,0,0" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="NewsPanel" />
        </ScrollViewer>

        <TextBlock Grid.Row="1" x:Name="LoadingText" Text="Loading news…"
                   Foreground="#66FFFFFF" HorizontalAlignment="Center" VerticalAlignment="Center" />
    </Grid>
</Page>
