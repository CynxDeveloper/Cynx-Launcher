<Page x:Class="SusanooLauncher.Pages.QuestsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="28,22,28,22">
        <Border CornerRadius="16" Background="#22000000" Padding="24" MaxWidth="640" HorizontalAlignment="Left">
            <StackPanel>
                <TextBlock Text="Daily Quests" FontSize="26" FontWeight="SemiBold" Foreground="#F2FFFFFF" />
                <TextBlock Margin="0,12,0,0" Foreground="#CCFFFFFF" TextWrapping="Wrap"
                           Text="Quest progress updates when you log into Fortnite. Pin, reroll, and complete quests from the in-game quest log." />
                <TextBlock Margin="0,16,0,0" Foreground="#88FFFFFF" Text="• Daily quests reset at shop rotation (UTC midnight)" />
                <TextBlock Margin="0,6,0,0" Foreground="#88FFFFFF" Text="• Seasonal quests follow your backend season config" />
            </StackPanel>
        </Border>
    </ScrollViewer>
</Page>
