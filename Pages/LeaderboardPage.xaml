<Page x:Class="SusanooLauncher.Pages.LeaderboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Background="Transparent">

    <Page.Resources>
        <Style x:Key="SusanooTabStyle" TargetType="ToggleButton">
            <Setter Property="Foreground" Value="#CCFFFFFF" />
            <Setter Property="Background" Value="#FF1A1F2E" />
            <Setter Property="Padding" Value="14,9" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="10" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FF252B3D" />
                                <Setter Property="Foreground" Value="#FFFFFFFF" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FF2A3145" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Margin="24,8,24,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Top 3 podium (Susanoo style) -->
        <Grid Grid.Row="0" Margin="0,8,0,24" Height="200">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="1.2*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- 2nd -->
            <StackPanel Grid.Column="0" VerticalAlignment="Bottom" HorizontalAlignment="Center">
                <Grid Width="76" Height="76" HorizontalAlignment="Center" Margin="0,0,0,10">
                    <Ellipse Fill="#FF141824" />
                    <Image x:Name="Podium2Skin" Stretch="UniformToFill" Width="76" Height="76">
                        <Image.Clip>
                            <EllipseGeometry Center="38,38" RadiusX="38" RadiusY="38" />
                        </Image.Clip>
                    </Image>
                    <Ellipse Width="76" Height="76" Stroke="#FFC0C0C0" StrokeThickness="3" Fill="Transparent" />
                </Grid>
                <TextBlock x:Name="Podium2Name" Text="—" Foreground="#FFFFFFFF" FontWeight="SemiBold" FontSize="14"
                           HorizontalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="150" />
                <TextBlock x:Name="Podium2Score" Text="0" Foreground="#99FFFFFF" FontSize="13"
                           HorizontalAlignment="Center" Margin="0,4,0,0" />
            </StackPanel>

            <!-- 1st -->
            <StackPanel Grid.Column="1" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,0,0,0">
                <Grid Width="96" Height="96" HorizontalAlignment="Center" Margin="0,0,0,12">
                    <Ellipse Fill="#FF141824" />
                    <Image x:Name="Podium1Skin" Stretch="UniformToFill" Width="96" Height="96">
                        <Image.Clip>
                            <EllipseGeometry Center="48,48" RadiusX="48" RadiusY="48" />
                        </Image.Clip>
                    </Image>
                    <Ellipse Width="96" Height="96" Stroke="#FFFFD54F" StrokeThickness="4" Fill="Transparent">
                        <Ellipse.Effect>
                            <DropShadowEffect Color="#FFFFD54F" BlurRadius="18" ShadowDepth="0" Opacity="0.35" />
                        </Ellipse.Effect>
                    </Ellipse>
                </Grid>
                <TextBlock x:Name="Podium1Name" Text="—" Foreground="#FFFFD54F" FontWeight="Bold" FontSize="16"
                           HorizontalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="180" />
                <TextBlock x:Name="Podium1Score" Text="0" Foreground="#CCFFFFFF" FontSize="14"
                           HorizontalAlignment="Center" Margin="0,4,0,0" />
            </StackPanel>

            <!-- 3rd -->
            <StackPanel Grid.Column="2" VerticalAlignment="Bottom" HorizontalAlignment="Center">
                <Grid Width="76" Height="76" HorizontalAlignment="Center" Margin="0,0,0,10">
                    <Ellipse Fill="#FF141824" />
                    <Image x:Name="Podium3Skin" Stretch="UniformToFill" Width="76" Height="76">
                        <Image.Clip>
                            <EllipseGeometry Center="38,38" RadiusX="38" RadiusY="38" />
                        </Image.Clip>
                    </Image>
                    <Ellipse Width="76" Height="76" Stroke="#FFCD7F32" StrokeThickness="3" Fill="Transparent" />
                </Grid>
                <TextBlock x:Name="Podium3Name" Text="—" Foreground="#FFFFFFFF" FontWeight="SemiBold" FontSize="14"
                           HorizontalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="150" />
                <TextBlock x:Name="Podium3Score" Text="0" Foreground="#99FFFFFF" FontSize="13"
                           HorizontalAlignment="Center" Margin="0,4,0,0" />
            </StackPanel>
        </Grid>

        <!-- Filters + search -->
        <Grid Grid.Row="1" Margin="0,0,0,14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Orientation="Horizontal">
                <ToggleButton x:Name="TabPoints" Click="TabPointsClicked" IsChecked="True" Style="{StaticResource SusanooTabStyle}">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Star24" FontSize="14" Margin="0,0,8,0" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}" />
                        <TextBlock Text="Points" VerticalAlignment="Center" />
                    </StackPanel>
                </ToggleButton>
                <ToggleButton x:Name="TabKills" Click="TabKillsClicked" Style="{StaticResource SusanooTabStyle}">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Target24" FontSize="14" Margin="0,0,8,0" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}" />
                        <TextBlock Text="Kills" VerticalAlignment="Center" />
                    </StackPanel>
                </ToggleButton>
                <ToggleButton x:Name="TabWins" Click="TabWinsClicked" Style="{StaticResource SusanooTabStyle}">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Trophy24" FontSize="14" Margin="0,0,8,0" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}" />
                        <TextBlock Text="Wins" VerticalAlignment="Center" />
                    </StackPanel>
                </ToggleButton>
            </StackPanel>

            <Grid Grid.Row="1" Margin="0,14,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ui:TextBox x:Name="SearchBox" PlaceholderText="Search for a player..." Height="42" />
                <ui:Button Grid.Column="1" Content="Search" Margin="10,0,0,0" Height="42" MinWidth="96"
                           Click="SearchClicked" Background="#FF3B82F6" Foreground="#FFFFFFFF" FontWeight="SemiBold" />
            </Grid>

            <TextBlock Grid.Row="1" x:Name="ErrorText" Foreground="#FFFF8A8A" FontSize="12"
                       TextWrapping="Wrap" Margin="0,52,0,0" Visibility="Collapsed" />
        </Grid>

        <!-- Table -->
        <Border Grid.Row="2" Background="#CC141824" CornerRadius="12" ClipToBounds="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Padding="18,12" Background="#FF0F1219">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="56" />
                            <ColumnDefinition Width="2.2*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="RANK" Foreground="#55FFFFFF" FontSize="11" FontWeight="Bold" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" Text="PLAYER" Foreground="#55FFFFFF" FontSize="11" FontWeight="Bold" VerticalAlignment="Center" />
                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <ui:SymbolIcon Symbol="Target24" FontSize="12" Foreground="#55FFFFFF" Margin="0,0,6,0" />
                            <TextBlock Text="KILLS" Foreground="#55FFFFFF" FontSize="11" FontWeight="Bold" />
                        </StackPanel>
                        <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                            <ui:SymbolIcon Symbol="Trophy24" FontSize="12" Foreground="#55FFFFFF" Margin="0,0,6,0" />
                            <TextBlock Text="WINS" Foreground="#55FFFFFF" FontSize="11" FontWeight="Bold" />
                        </StackPanel>
                        <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                            <ui:SymbolIcon Symbol="Star24" FontSize="12" Foreground="#55FFFFFF" Margin="0,0,6,0" />
                            <TextBlock Text="POINTS" Foreground="#55FFFFFF" FontSize="11" FontWeight="Bold" />
                        </StackPanel>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="LeaderboardList" />
                </ScrollViewer>

                <TextBlock Grid.Row="1" x:Name="LoadingText" Text="Loading leaderboard…"
                           Foreground="#66FFFFFF" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="13" />
            </Grid>
        </Border>

        <!-- Footer countdown -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Grid Width="22" Height="22" Margin="0,0,10,0">
                <Ellipse Width="22" Height="22" Stroke="#3322C55E" StrokeThickness="2.5" />
                <Ellipse x:Name="RefreshProgressRing" Width="22" Height="22" Stroke="#FF22C55E" StrokeThickness="2.5"
                         StrokeDashCap="Round" RenderTransformOrigin="0.5,0.5">
                    <Ellipse.RenderTransform>
                        <RotateTransform Angle="-90" />
                    </Ellipse.RenderTransform>
                </Ellipse>
            </Grid>
            <TextBlock x:Name="UpdateTimerText" Foreground="#88FFFFFF" FontSize="12" VerticalAlignment="Center"
                       Text="Next update in --:--" />
        </StackPanel>
    </Grid>
</Page>
