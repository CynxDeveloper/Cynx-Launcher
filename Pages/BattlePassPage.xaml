<Page x:Class="SusanooLauncher.Pages.BattlePassPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="28,22,28,22">
        <Border CornerRadius="16" Background="#22000000" Padding="24" MaxWidth="640" HorizontalAlignment="Left">
            <StackPanel>
                <TextBlock Text="Battle Pass" FontSize="26" FontWeight="SemiBold" Foreground="#F2FFFFFF" />
                <TextBlock x:Name="SeasonText" Margin="0,8,0,0" Foreground="#99FFFFFF" FontSize="14" />
                <TextBlock Margin="0,16,0,0" Foreground="#CCFFFFFF" TextWrapping="Wrap"
                           Text="Purchase tiers and claim rewards in-game. Progress syncs when you play on Susanoo." />
                <TextBlock x:Name="LevelText" Margin="0,12,0,0" FontSize="18" FontWeight="SemiBold" Foreground="#FF8EC5FF" />
            </StackPanel>
        </Border>
    </ScrollViewer>
</Page>
