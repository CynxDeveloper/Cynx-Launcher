<UserControl x:Class="SusanooLauncher.Controls.CircularSkinAvatar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root"
             SnapsToDevicePixels="True">

    <Grid Width="{Binding Diameter, ElementName=Root}"
          Height="{Binding Diameter, ElementName=Root}">
        <Ellipse Fill="{Binding BackgroundFill, ElementName=Root}" />
        <Image x:Name="SkinImage"
               Stretch="UniformToFill"
               Width="{Binding Diameter, ElementName=Root}"
               Height="{Binding Diameter, ElementName=Root}" />
        <Ellipse Width="{Binding Diameter, ElementName=Root}"
                 Height="{Binding Diameter, ElementName=Root}"
                 Stroke="{Binding RingBrush, ElementName=Root}"
                 StrokeThickness="{Binding RingThickness, ElementName=Root}"
                 Fill="Transparent" />
    </Grid>
</UserControl>
